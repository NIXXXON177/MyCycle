<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Florea"
        android:textColor="#FFAD1457"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/widget_cycle_day"
        android:textColor="#FF757575"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/cycle_day_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#FF880E4F"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/phase_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="—"
        android:textColor="#FF424242"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/widget_days_until"
        android:textColor="#FF757575"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/days_until_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#FF424242"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
